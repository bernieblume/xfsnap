#!/usr/bin/env zsh
#
# xfsnap - transfer Solana (Agave) snapshots between validator hosts, fast.
#
# Full snapshots are a single large .tar.zst file. To saturate a long-fat WAN
# link we split the file into fixed-size byte-range chunks and push them with N
# concurrent `dd | ssh dd seek` streams straight into a pre-allocated file on
# the destination (no reassembly step). Progress + full resume via a small
# ledger under <dstdir>/.xfsnap/.
#
# Self-contained: copy this one file to ~/ or /usr/local/bin on each host.
# Requires: zsh, GNU coreutils (dd, truncate, stat), ssh, zstd. solana CLI
# optional (used only for the pre-snapshot timing guard).
#
# Subcommands (aliases):
#   help  h              this text
#   get   g              pull newest full snapshot from peer  -> here
#   getinc  gi           pull newest incremental from peer    -> here
#   put   p              push newest full snapshot here        -> peer
#   putinc  pi           push newest incremental here          -> peer
#   transfer  trf  SRC DST     push newest full  SRC -> DST (ssh short names)
#   transferinc trfi SRC DST   push newest incremental SRC -> DST
#
# Common options:
#   --streams N     concurrent streams (default 8)
#   --chunk BYTES   chunk size (default 1073741824 = 1 GiB; accepts 512M, 2G)
#   --yes           don't prompt (assume yes to the pre-snapshot guard)
#   --no-verify     skip the final `zstd -t` integrity test on the dest
#   --verify        also checksum every chunk (sha256) end-to-end (slow)
#   --watch         (putinc/getinc) loop forever, shipping each new incremental
#   --dry-run       show the plan, transfer nothing
#
emulate -L zsh
setopt pipe_fail no_unset warn_create_global

##############################################################################
# Config
##############################################################################
FULL_INTERVAL=100000            # --full-snapshot-interval-slots default (Agave v3+)
SLOT_TIME=0.4                   # seconds per slot (mainnet ~0.4)
GUARD_SECONDS=3600              # warn if a new full snapshot is due within this
CHUNK_DEFAULT=$((1024*1024*1024))   # 1 GiB
STREAMS_DEFAULT=8
DD_BS=$((4*1024*1024))          # dd block size for throughput (4 MiB)
CIPHER=${XFSNAP_CIPHER:-aes128-gcm@openssh.com}

# ssh options shared by every remote invocation. No compression (snapshots are
# already zstd), fast AEAD cipher, separate TCP per chunk = real parallel streams.
SSHOPTS=(-o Compression=no -o ConnectTimeout=10 -o ServerAliveInterval=15 -c "$CIPHER")

##############################################################################
# Host table  (key = ssh short name from ~/.ssh/config)
#   SNAP  = dir holding snapshot-<slot>-<hash>.tar.zst  (full snapshots)
#   INC   = dir holding incremental-snapshot-<base>-<slot>-<hash>.tar.zst
#   PEER  = the paired host for bare get/put
#   MATCH = `hostname -s` value used to auto-detect "am I this host?"
##############################################################################
typeset -A HOST_SNAP HOST_INC HOST_PEER HOST_MATCH
HOST_SNAP[vn]=/mnt/snap        ; HOST_INC[vn]=/mnt/ledger ; HOST_PEER[vn]=ve ; HOST_MATCH[vn]=nodeA
HOST_SNAP[ve]=/mnt/snap        ; HOST_INC[ve]=/mnt/snap   ; HOST_PEER[ve]=vn ; HOST_MATCH[ve]=nodeB
# --- test rigs ---
HOST_SNAP[lb]=/mnt/data1/xfsnap/snap    ; HOST_INC[lb]=/mnt/data1/xfsnap/inc    ; HOST_PEER[lb]=ta ; HOST_MATCH[lb]=nodeC
HOST_SNAP[ta]=/mnt/data2/xfsnap/snap ; HOST_INC[ta]=/mnt/data2/xfsnap/inc ; HOST_PEER[ta]=lb ; HOST_MATCH[ta]=nodeD

##############################################################################
# Pretty output
##############################################################################
typeset -g PROG_TTY
if [[ -t 2 ]]; then
  C_RED=$'\e[31m'; C_YEL=$'\e[33m'; C_GRN=$'\e[32m'; C_DIM=$'\e[2m'; C_BLD=$'\e[1m'; C_RST=$'\e[0m'; PROG_TTY=1
else
  C_RED= ; C_YEL= ; C_GRN= ; C_DIM= ; C_BLD= ; C_RST= ; PROG_TTY=0
fi
info()  { print -r -- "${C_DIM}::${C_RST} $*" >&2 }
step()  { print -r -- "${C_BLD}==>${C_RST} $*" >&2 }
warn()  { print -r -- "${C_YEL}warn:${C_RST} $*" >&2 }
die()   { print -r -- "${C_RED}error:${C_RST} $*" >&2; exit 1 }
ok()    { print -r -- "${C_GRN}ok:${C_RST} $*" >&2 }

##############################################################################
# Small helpers
##############################################################################
# parse a size like 512M / 2G / 1073741824 into bytes
parse_size() {
  local s=$1
  case $s in
    *[gG]) print -r -- $(( ${s%[gG]} * 1024*1024*1024 )) ;;
    *[mM]) print -r -- $(( ${s%[mM]} * 1024*1024 )) ;;
    *[kK]) print -r -- $(( ${s%[kK]} * 1024 )) ;;
    *)     print -r -- $s ;;
  esac
}

human() {  # bytes -> human string
  local b=$1
  if   (( b >= 1024**3 )); then printf '%.2f GiB' $(( b/1024.0**3 ))
  elif (( b >= 1024**2 )); then printf '%.1f MiB' $(( b/1024.0**2 ))
  elif (( b >= 1024 ));    then printf '%.1f KiB' $(( b/1024.0 ))
  else                          printf '%d B' $b ; fi
}

hms() {  # seconds -> HH:MM:SS
  local t=$1; (( t < 0 )) && t=0
  printf '%02d:%02d:%02d' $(( t/3600 )) $(( (t%3600)/60 )) $(( t%60 ))
}

# run a command either locally or on a remote ssh host.
# usage: at <sshname|LOCAL> <command-string>
at() {
  local host=$1; shift
  if [[ $host == LOCAL ]]; then
    eval "$*"
  else
    ssh "${SSHOPTS[@]}" "$host" "$*"
  fi
}

# file size in bytes (endpoint may be LOCAL or an ssh name)
fsize() {
  local host=$1 pth=$2
  at "$host" "stat -c %s -- '$pth' 2>/dev/null || echo -1"
}

##############################################################################
# Identity / endpoint resolution
##############################################################################
SELF=
resolve_self() {
  local hn=${XFSNAP_SELF:-$(hostname -s 2>/dev/null || hostname)}
  local k
  for k in ${(k)HOST_MATCH}; do
    if [[ $k == $hn || $HOST_MATCH[$k] == $hn ]]; then SELF=$k; return 0; fi
  done
  SELF=   # unknown host (e.g. laptop) -> only `transfer` works
}

# validate an endpoint key exists in the table
known_host() { [[ -n ${HOST_SNAP[$1]:-} ]] }

# is endpoint the local machine?
is_local() { [[ -n $SELF && $1 == $SELF ]] }

##############################################################################
# Snapshot discovery
##############################################################################
# newest full snapshot filename (basename) in dir, by highest slot. empty if none.
# List the dir and filter locally -- no remote glob (avoids zsh nomatch errors
# and works regardless of the remote login shell).
newest_full() {
  local host=$1 dir=$2
  at "$host" "ls -1 '$dir' 2>/dev/null" | \
    while read -r b; do
      [[ $b == snapshot-*.tar.zst ]] || continue
      local slot=${${b#snapshot-}%%-*}
      [[ $slot == <-> ]] && print -r -- "$slot $b"
    done | sort -n -k1,1 | tail -1 | cut -d' ' -f2-
}

# newest incremental filename by highest tip slot. empty if none.
newest_inc() {
  local host=$1 dir=$2
  at "$host" "ls -1 '$dir' 2>/dev/null" | \
    while read -r b; do
      [[ $b == incremental-snapshot-*.tar.zst ]] || continue
      local rest=${b#incremental-snapshot-}
      local base=${rest%%-*}
      local tip=${${rest#*-}%%-*}
      [[ $base == <-> && $tip == <-> ]] && print -r -- "$tip $b"
    done | sort -n -k1,1 | tail -1 | cut -d' ' -f2-
}

full_slot() { local b=$1; print -r -- ${${b#snapshot-}%%-*} }
inc_base()  { local b=$1; local r=${b#incremental-snapshot-}; print -r -- ${r%%-*} }
inc_tip()   { local b=$1; local r=${b#incremental-snapshot-}; print -r -- ${${r#*-}%%-*} }

# current cluster slot (override via XFSNAP_NOW_SLOT for testing)
current_slot() {
  if [[ -n ${XFSNAP_NOW_SLOT:-} ]]; then print -r -- $XFSNAP_NOW_SLOT; return 0; fi
  local s
  s=$(command solana slot 2>/dev/null) || return 1
  [[ $s == <-> ]] && print -r -- $s || return 1
}

##############################################################################
# Pre-snapshot timing guard  (only relevant for full snapshots)
# Returns 0 = proceed, 1 = abort.
##############################################################################
guard_full() {
  local snapslot=$1 assume_yes=$2
  local now
  if ! now=$(current_slot); then
    warn "couldn't get current slot (solana slot); skipping timing guard"
    return 0
  fi
  local next=$(( snapslot + FULL_INTERVAL ))
  # snapshots land on interval multiples; next one after 'now' is the ceiling
  if (( now >= next )); then
    # a newer full is already due/overdue relative to this snapshot
    next=$(( ( now / FULL_INTERVAL + 1 ) * FULL_INTERVAL ))
  fi
  local slots_left=$(( next - now ))
  local secs_left=$(( slots_left * SLOT_TIME ))
  info "current slot $now, this snapshot slot $snapslot"
  info "next full snapshot ~slot $next ($slots_left slots, ~$(hms $secs_left) away)"
  if (( secs_left < GUARD_SECONDS )); then
    warn "a new full snapshot is due in ~$(hms $secs_left) (< $(hms $GUARD_SECONDS))."
    warn "it may be better to wait for it than to ship this soon-to-be-stale one."
    if [[ $assume_yes == 1 ]]; then
      warn "--yes given, proceeding anyway."
      return 0
    fi
    printf '%s' "Proceed anyway? [y/N] " >&2
    local ans; read -r ans
    [[ $ans == [yY]* ]] && return 0 || return 1
  fi
  return 0
}

##############################################################################
# The transfer engine
#
#   xfer <SRC_EP> <SRC_PATH> <DST_EP> <DST_DIR> <NAME>
#
# Exactly one of SRC_EP / DST_EP must be LOCAL (the box running this).
# Streams NAME from SRC_DIR into <DST_DIR>/NAME on the destination, chunked
# and resumable. Ledger + staging live in <DST_DIR>/.xfsnap/.
##############################################################################
STREAMS=$STREAMS_DEFAULT
CHUNK=$CHUNK_DEFAULT
OPT_YES=0 OPT_VERIFY=0 OPT_NOVERIFY=0 OPT_DRY=0

xfer() {
  local SRC_EP=$1 SRC_PATH=$2 DST_EP=$3 DST_DIR=$4 NAME=$5
  local FINAL="$DST_DIR/$NAME"
  local PART="$DST_DIR/.xfsnap/$NAME.part"
  local LEDGER="$DST_DIR/.xfsnap/$NAME.state"
  local STATEDIR="$DST_DIR/.xfsnap"

  # size of the source file
  local SIZE; SIZE=$(fsize "$SRC_EP" "$SRC_PATH")
  (( SIZE > 0 )) || die "source file missing or empty: $SRC_PATH"

  local CHUNKS=$(( (SIZE + CHUNK - 1) / CHUNK ))
  step "transfer ${C_BLD}$NAME${C_RST}  $(human $SIZE)  ($CHUNKS chunks x $(human $CHUNK), $STREAMS streams)"
  info "src ${SRC_EP}:$SRC_PATH  ->  dst ${DST_EP}:$FINAL"

  if (( OPT_DRY )); then info "dry-run: nothing transferred"; return 0; fi

  # ensure dest dir + statedir exist
  at "$DST_EP" "mkdir -p '$DST_DIR' '$STATEDIR'"

  # ---- resume logic: is there a consistent ledger + part to continue? ----
  local -A DONE
  local hdr have_part reuse=0
  hdr=$(at "$DST_EP" "head -1 '$LEDGER' 2>/dev/null || true")
  have_part=$(fsize "$DST_EP" "$PART")
  if [[ $hdr == "# xfsnap size=$SIZE chunk=$CHUNK"* ]] && (( have_part == SIZE )); then
    reuse=1
    local line
    while read -r line; do
      [[ $line == '#'* || -z $line ]] && continue
      DONE[$line]=1
    done < <(at "$DST_EP" "cat '$LEDGER' 2>/dev/null || true")
    info "resuming: ${#DONE} / $CHUNKS chunks already done"
  fi

  if (( ! reuse )); then
    # fresh start: (re)create part at full size + fresh ledger header
    at "$DST_EP" "rm -f '$PART' '$LEDGER'; truncate -s $SIZE '$PART'; printf '# xfsnap size=%s chunk=%s name=%s\n' $SIZE $CHUNK '$NAME' > '$LEDGER'"
  fi

  # ---- build pending chunk list ----
  local -a pending; local i
  for (( i=0; i<CHUNKS; i++ )); do
    [[ -n ${DONE[$i]:-} ]] || pending+=$i
  done
  local base_done=$(( CHUNKS - ${#pending} ))
  if (( ${#pending} == 0 )); then
    info "all chunks already present"
  else
    # local scratch for progress accounting
    local scratch; scratch=$(mktemp -d "${TMPDIR:-/tmp}/xfsnap.XXXXXX")
    local donef="$scratch/done" failf="$scratch/fail"
    : >| "$donef"; : >| "$failf"
    local t0=$SECONDS
    local last_prog=-100   # throttle clock for non-tty progress lines

    # worker: transfer one chunk i.
    # The RECEIVER marks the chunk done in the ledger ONLY if it wrote exactly
    # 'len' bytes. This is the safety net: if the reader is SIGKILLed mid-chunk
    # its pipe partner sees a clean EOF and would otherwise exit 0 with partial
    # data -- the byte-count check rejects that, so the chunk is redone on resume
    # (its partial bytes get overwritten). conv=notrunc keeps other chunks intact.
    _chunk() {
      local idx=$1
      local off=$(( idx * CHUNK ))
      local len=$(( SIZE - off )); (( len > CHUNK )) && len=$CHUNK
      local rd="dd if='$SRC_PATH' bs=$DD_BS skip=$off count=$len iflag=skip_bytes,count_bytes status=none"
      local wr="n=\$(dd of='$PART' bs=$DD_BS seek=$off oflag=seek_bytes conv=notrunc 2>&1 | awk '/ bytes /{print \$1; exit}'); [ \"\$n\" = \"$len\" ] && printf '%s\n' $idx >> '$LEDGER'"
      if [[ $SRC_EP == LOCAL ]]; then
        eval "$rd" | ssh "${SSHOPTS[@]}" "$DST_EP" "$wr"
      else
        ssh "${SSHOPTS[@]}" "$SRC_EP" "$rd" | eval "$wr"
      fi
      if (( $? == 0 )); then print -r -- $idx >> "$donef"
      else print -r -- $idx >> "$failf"; fi
    }

    # progress bar
    _bar() {
      local dn=$1 total=$2 elapsed=$3
      local pct=$(( total>0 ? dn*100/total : 100 ))
      local width=28
      local filled=$(( pct*width/100 ))
      local bar=; local j
      for (( j=0; j<width; j++ )); do (( j<filled )) && bar+='#' || bar+='-'; done
      local bytes=$(( dn*CHUNK )); (( bytes>SIZE )) && bytes=$SIZE
      local rate=0 eta=0
      (( elapsed>0 )) && rate=$(( bytes/elapsed ))
      (( rate>0 )) && eta=$(( (SIZE-bytes)/rate ))
      if (( PROG_TTY )); then
        printf '\r%s[%s] %3d%%  %d/%d  %s/s  ETA %s%s' \
          "$C_DIM" "$bar" $pct $dn $total "$(human $rate)" "$(hms $eta)" "$C_RST" >&2
      elif (( SECONDS - last_prog >= 5 || dn >= total )); then
        last_prog=$SECONDS   # throttled newline updates when logging to a file
        printf '  %3d%%  %d/%d chunks  %s/s  ETA %s\n' \
          $pct $dn $total "$(human $rate)" "$(hms $eta)" >&2
      fi
    }

    # completed = lines written by workers to done + fail files (source of truth)
    _completed() { print -r -- $(( $(wc -l < "$donef") + $(wc -l < "$failf") )) }

    # launch pool, capping in-flight at STREAMS by watching the completion count
    local launched=0 npend=${#pending}
    for i in $pending; do
      while (( launched - $(_completed) >= STREAMS )); do
        _bar $(( base_done + $(wc -l < "$donef") )) $CHUNKS $(( SECONDS - t0 ))
        sleep 0.1
      done
      _chunk $i &
      (( ++launched ))
    done
    # drain
    while (( $(_completed) < npend )); do
      _bar $(( base_done + $(wc -l < "$donef") )) $CHUNKS $(( SECONDS - t0 ))
      sleep 0.1
    done
    wait
    _bar $(( base_done + $(wc -l < "$donef") )) $CHUNKS $(( SECONDS - t0 ))
    print >&2   # newline after bar

    local nfail=$(wc -l < "$failf")
    rm -rf "$scratch"
    if (( nfail > 0 )); then
      warn "$nfail chunk(s) failed; ledger preserved. re-run the same command to resume."
      return 1
    fi
  fi

  # ---- finalize: verify completeness from the authoritative dst ledger ----
  # count UNIQUE chunk indices (defensive against any duplicate ledger lines)
  local ndone
  ndone=$(at "$DST_EP" "grep '^[0-9]' '$LEDGER' 2>/dev/null | sort -un | wc -l")
  if (( ndone < CHUNKS )); then
    warn "only $ndone/$CHUNKS chunks confirmed in ledger; re-run to resume."
    return 1
  fi

  # optional per-chunk deep verify
  if (( OPT_VERIFY )); then
    step "verifying source vs dest checksum"
    local ssum dsum
    ssum=$(at "$SRC_EP" "sha256sum -- '$SRC_PATH'" | cut -d' ' -f1)
    dsum=$(at "$DST_EP" "sha256sum -- '$PART'"     | cut -d' ' -f1)
    [[ $ssum == $dsum ]] || die "checksum mismatch! src=$ssum dst=$dsum (ledger kept)"
    ok "sha256 match ($ssum)"
  fi

  # atomic publish
  at "$DST_EP" "mv -f '$PART' '$FINAL'"

  if (( ! OPT_NOVERIFY )); then
    step "zstd integrity test on dest"
    if at "$DST_EP" "zstd -t -- '$FINAL'" >/dev/null 2>&1; then
      ok "zstd -t passed"
    else
      die "zstd -t FAILED on dest: $FINAL"
    fi
  fi

  # clean the ledger (keep .part gone; leave dir)
  at "$DST_EP" "rm -f '$LEDGER'"
  ok "delivered ${DST_EP}:$FINAL"
}

##############################################################################
# High-level operations
##############################################################################
# resolve a (host, kind) -> dir  ; kind = snap|inc
dir_of() {
  local host=$1 kind=$2
  known_host "$host" || die "unknown host '$host' (not in table)"
  [[ $kind == snap ]] && print -r -- ${HOST_SNAP[$host]} || print -r -- ${HOST_INC[$host]}
}

# endpoint token for xfer: LOCAL if it's us, else the ssh name
ep_of() { is_local "$1" && print -r -- LOCAL || print -r -- "$1" }

do_full() {  # SRC DST
  local SRC=$1 DST=$2
  local sdir=$(dir_of "$SRC" snap) ddir=$(dir_of "$DST" snap)
  local sep=$(ep_of "$SRC") dep=$(ep_of "$DST")

  # remote->remote: hop to the source so bytes flow src->dst directly
  if [[ $sep != LOCAL && $dep != LOCAL ]]; then
    step "neither endpoint local; hopping to $SRC to run the transfer there"
    ssh "${SSHOPTS[@]}" "$SRC" "xfsnap transfer $SRC $DST ${(j: :)FWD_OPTS}"
    return $?
  fi

  local name; name=$(newest_full "$sep" "$sdir")
  [[ -n $name ]] || die "no full snapshot found in ${SRC}:$sdir"
  local slot; slot=$(full_slot "$name")

  # timing guard only makes sense when SRC is a live validator (we run there)
  if [[ $sep == LOCAL ]]; then
    guard_full "$slot" "$OPT_YES" || die "aborted by timing guard"
  fi
  xfer "$sep" "$sdir/$name" "$dep" "$ddir" "$name"
}

do_inc() {  # SRC DST  (single shot: wait for a fresh incremental, then ship it)
  local SRC=$1 DST=$2
  local sdir=$(dir_of "$SRC" inc) ddir=$(dir_of "$DST" inc)
  local ssnap=$(dir_of "$SRC" snap) dsnap=$(dir_of "$DST" snap)
  local sep=$(ep_of "$SRC") dep=$(ep_of "$DST")

  if [[ $sep != LOCAL && $dep != LOCAL ]]; then
    step "neither endpoint local; hopping to $SRC"
    ssh "${SSHOPTS[@]}" "$SRC" "xfsnap transferinc $SRC $DST ${(j: :)FWD_OPTS}"
    return $?
  fi

  _ship_one_inc() {
    local name=$1
    local base; base=$(inc_base "$name")
    # the incremental is only usable if its base full snapshot exists on dst
    local basefull; basefull=$(at "$dep" "ls -1 '$dsnap' 2>/dev/null" | grep -E "^snapshot-$base-.*\.tar\.zst$" | head -1)
    if [[ -z $basefull ]]; then
      warn "dest is missing base full snapshot for slot $base"
      warn "the incremental won't be usable until you 'put' that full. shipping anyway."
    fi
    xfer "$sep" "$sdir/$name" "$dep" "$ddir" "$name"
  }

  local last; last=$(newest_inc "$sep" "$sdir")
  local last_tip=0; [[ -n $last ]] && last_tip=$(inc_tip "$last")

  # --now: ship whatever's newest right away instead of waiting for the next one.
  # One-shot: ship and exit. With --watch: ship now, then keep shipping newer.
  if (( OPT_NOW )); then
    if [[ -n $last ]]; then
      step "shipping current newest incremental now: $last"
      if (( OPT_WATCH )); then
        _ship_one_inc "$last" || warn "ship failed, will retry on next one"
      else
        _ship_one_inc "$last"; return $?
      fi
    else
      info "no incremental present yet; falling back to waiting for the next one"
    fi
  fi

  if (( OPT_WATCH )); then
    step "watching ${SRC}:$sdir for new incrementals (Ctrl-C to stop)"
    info "baseline: ${last:-<none>} (tip $last_tip)"
    while true; do
      local cur; cur=$(newest_inc "$sep" "$sdir")
      local tip=0; [[ -n $cur ]] && tip=$(inc_tip "$cur")
      if (( tip > last_tip )); then
        last_tip=$tip
        step "new incremental: $cur"
        _ship_one_inc "$cur" || warn "ship failed, will retry on next one"
      fi
      sleep 2
    done
  else
    # one-shot: wait until a *newer* incremental than the current one appears,
    # then ship it immediately (freshest possible).
    step "waiting for the next incremental after ${last:-<none>} ..."
    while true; do
      local cur; cur=$(newest_inc "$sep" "$sdir")
      local tip=0; [[ -n $cur ]] && tip=$(inc_tip "$cur")
      if (( tip > last_tip )); then
        step "new incremental: $cur"
        _ship_one_inc "$cur"
        return $?
      fi
      sleep 2
    done
  fi
}

# remove leftover staging (.part/.state) from this host's snap+inc dirs.
# Safe: staging is only resume state. Don't run during an active transfer
# (it would force any in-progress resume to restart from scratch).
do_clean() {
  [[ -n $SELF ]] || die "clean must run on a host in the table"
  local d cnt=0 freed=0 f sz
  for d in "${HOST_SNAP[$SELF]}" "${HOST_INC[$SELF]}"; do
    [[ -d $d/.xfsnap ]] || continue
    for f in "$d"/.xfsnap/*.part(N) "$d"/.xfsnap/*.state(N); do
      sz=$(stat -c %s -- "$f" 2>/dev/null || echo 0)
      (( freed += sz )); (( cnt++ ))
      info "removing ${f}"
      rm -f -- "$f"
    done
  done
  ok "cleaned $cnt staging file(s), freed ~$(human $freed)"
}

##############################################################################
# Usage
##############################################################################
usage() {
  cat >&2 <<'EOF'
xfsnap - fast Solana snapshot transfer between validator hosts

USAGE
  xfsnap <subcommand> [options]

SUBCOMMANDS (aliases)
  help  h                    show this help
  get   g                    pull newest full snapshot: peer -> here
  getinc  gi                 pull newest incremental:   peer -> here
  put   p                    push newest full snapshot: here -> peer
  putinc  pi                 push newest incremental:   here -> peer
  transfer  trf  SRC DST     push newest full   SRC -> DST  (ssh short names)
  transferinc trfi SRC DST   push newest incremental SRC -> DST
  clean  cl                  remove leftover .xfsnap staging on this host

OPTIONS
  --streams N     concurrent streams (default 8)
  --chunk SIZE    chunk size, e.g. 512M, 2G (default 1G)
  --yes           assume yes to the pre-snapshot timing guard
  --no-verify     skip final `zstd -t` on the dest
  --verify        also sha256 the whole file end-to-end (slow)
  --watch         (putinc/getinc) loop, shipping each new incremental
  --now           (putinc/getinc) ship the current newest now, don't wait
  --dry-run       show plan only

Host table (edit in the script):
  vn  /mnt/snap  + /mnt/ledger   peer ve
  ve  /mnt/snap  + /mnt/snap      peer vn
EOF
}

##############################################################################
# Arg parsing / dispatch
##############################################################################
OPT_WATCH=0
OPT_NOW=0
FWD_OPTS=()   # options to forward when hopping to the source

parse_common_opts() {
  local -a rest
  while (( $# )); do
    case $1 in
      --streams)   STREAMS=$2; FWD_OPTS+=(--streams $2); shift 2 ;;
      --chunk)     CHUNK=$(parse_size $2); FWD_OPTS+=(--chunk $2); shift 2 ;;
      --yes|-y)    OPT_YES=1; FWD_OPTS+=(--yes); shift ;;
      --no-verify) OPT_NOVERIFY=1; FWD_OPTS+=(--no-verify); shift ;;
      --verify)    OPT_VERIFY=1; FWD_OPTS+=(--verify); shift ;;
      --watch)     OPT_WATCH=1; FWD_OPTS+=(--watch); shift ;;
      --now)       OPT_NOW=1; FWD_OPTS+=(--now); shift ;;
      --dry-run)   OPT_DRY=1; FWD_OPTS+=(--dry-run); shift ;;
      --)          shift; rest+=("$@"); break ;;
      -*)          die "unknown option: $1" ;;
      *)           rest+=($1); shift ;;
    esac
  done
  POSARGS=("${rest[@]}")
}

main() {
  resolve_self
  (( $# )) || { usage; exit 1; }
  local cmd=$1; shift
  typeset -ga POSARGS
  parse_common_opts "$@"

  case $cmd in
    help|h|-h|--help) usage ;;

    put|p)
      [[ -n $SELF ]] || die "can't 'put' from this host (not in table); use: xfsnap transfer SRC DST"
      do_full "$SELF" "${HOST_PEER[$SELF]}" ;;
    get|g)
      [[ -n $SELF ]] || die "can't 'get' on this host (not in table); use: xfsnap transfer SRC DST"
      do_full "${HOST_PEER[$SELF]}" "$SELF" ;;
    putinc|pi)
      [[ -n $SELF ]] || die "can't 'putinc' from this host; use: xfsnap transferinc SRC DST"
      do_inc "$SELF" "${HOST_PEER[$SELF]}" ;;
    getinc|gi)
      [[ -n $SELF ]] || die "can't 'getinc' on this host; use: xfsnap transferinc SRC DST"
      do_inc "${HOST_PEER[$SELF]}" "$SELF" ;;

    clean|cl)
      do_clean ;;

    transfer|trf)
      (( ${#POSARGS} == 2 )) || die "usage: xfsnap transfer SRC DST"
      do_full "${POSARGS[1]}" "${POSARGS[2]}" ;;
    transferinc|trfi)
      (( ${#POSARGS} == 2 )) || die "usage: xfsnap transferinc SRC DST"
      do_inc "${POSARGS[1]}" "${POSARGS[2]}" ;;

    *) die "unknown subcommand: $cmd (try 'xfsnap help')" ;;
  esac
}

main "$@"
