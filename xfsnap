#!/usr/bin/env bash
#
# xfsnap - transfer Solana (Agave) snapshots between validator hosts, fast.
#
# A full snapshot is one large .tar.zst. To saturate a long-fat WAN link (a
# single TCP flow can't) xfsnap splits the file into fixed-size byte ranges and
# pushes them with N concurrent `dd | ssh dd seek` streams straight into a
# pre-allocated file on the destination -- no reassembly. Progress + full resume
# via a small ledger under <dstdir>/.xfsnap/.
#
# Self-contained single file: `xfsnap install` copies it to /usr/local/bin.
# Each host describes only ITSELF via `xfsnap config` (snapshot dirs + peer);
# the source discovers a destination's dirs by asking it over ssh. No central
# host list, no hardcoded paths.
#
# Requires: bash 4+, GNU coreutils (dd, truncate, stat), ssh, zstd, awk. The
# solana CLI is optional (used only for the pre-snapshot timing guard).
#
set -uo pipefail

if [ -z "${BASH_VERSINFO:-}" ] || [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
  echo "xfsnap needs bash 4+ (for associative arrays)" >&2; exit 1
fi

VERSION=0.7.5
SCRIPT_PATH="$(realpath -- "$0" 2>/dev/null || echo "$0")"
XFSNAP_REPO=${XFSNAP_REPO:-bernieblume/xfsnap}   # source for `xfsnap upgrade`
XFSNAP_BRANCH=${XFSNAP_BRANCH:-main}

##############################################################################
# Built-in defaults (overridable via `xfsnap config` or CLI flags)
##############################################################################
FULL_INTERVAL=100000            # --full-snapshot-interval-slots default (Agave v3+)
# slot time ~0.4s = 2/5 (bash has no float arithmetic; we use the 2/5 form)
GUARD_SECONDS=3600              # warn if a new full snapshot is due within this
CHUNK_DEFAULT=$((1024*1024*1024))   # 1 GiB
STREAMS_DEFAULT=8
DD_BS=$((4*1024*1024))          # dd block size for throughput (4 MiB)
CIPHER=aes128-gcm@openssh.com   # fast AEAD; snapshots are already zstd
SOLANA_BIN=solana

##############################################################################
# Pretty output (all diagnostics to stderr; stdout stays clean for `config get`)
##############################################################################
if [ -t 2 ]; then
  C_RED=$'\e[31m'; C_YEL=$'\e[33m'; C_GRN=$'\e[32m'; C_DIM=$'\e[2m'; C_BLD=$'\e[1m'; C_RST=$'\e[0m'; PROG_TTY=1
else
  C_RED= ; C_YEL= ; C_GRN= ; C_DIM= ; C_BLD= ; C_RST= ; PROG_TTY=0
fi
info()  { printf '%s:: %s%s\n' "$C_DIM" "$*" "$C_RST" >&2; }
step()  { printf '%s==>%s %s\n' "$C_BLD" "$C_RST" "$*" >&2; }
warn()  { printf '%swarn:%s %s\n' "$C_YEL" "$C_RST" "$*" >&2; }
die()   { printf '%serror:%s %s\n' "$C_RED" "$C_RST" "$*" >&2; exit 1; }
bad()   { printf '%sfail:%s %s\n' "$C_RED" "$C_RST" "$*" >&2; }
ok()    { printf '%sok:%s %s\n' "$C_GRN" "$C_RST" "$*" >&2; }

##############################################################################
# Small helpers
##############################################################################
parse_size() {  # 512M / 2G / 1073741824 -> bytes
  local s=$1
  case $s in
    *[gG]) echo $(( ${s%[gG]} * 1024*1024*1024 )) ;;
    *[mM]) echo $(( ${s%[mM]} * 1024*1024 )) ;;
    *[kK]) echo $(( ${s%[kK]} * 1024 )) ;;
    *)     echo "$s" ;;
  esac
}
human() {  # bytes -> human string (awk: bash has no float math)
  awk -v b="$1" 'BEGIN{
    if      (b>=1073741824) printf "%.2f GiB", b/1073741824;
    else if (b>=1048576)    printf "%.1f MiB", b/1048576;
    else if (b>=1024)       printf "%.1f KiB", b/1024;
    else                    printf "%d B", b;
  }'
}
hms() {  # seconds -> HH:MM:SS
  local t=$1; (( t < 0 )) && t=0
  printf '%02d:%02d:%02d' $(( t/3600 )) $(( (t%3600)/60 )) $(( t%60 ))
}
ver_cmp() {  # echo -1 / 0 / 1  for  $1 </=/> $2  (numeric semver fields)
  [ "$1" = "$2" ] && { echo 0; return; }
  local IFS=. i a b
  local -a A=($1) B=($2)
  for i in 0 1 2; do
    a=${A[i]:-0}; b=${B[i]:-0}; a=${a//[!0-9]/}; b=${b//[!0-9]/}; a=${a:-0}; b=${b:-0}
    (( 10#$a > 10#$b )) && { echo 1; return; }
    (( 10#$a < 10#$b )) && { echo -1; return; }
  done
  echo 0
}
# direction-aware sync hint given a peer host + its version
ver_hint() {
  local host=$1 pv=$2
  if [ "$(ver_cmp "$VERSION" "$pv")" = 1 ]; then echo "peer is older — push this build there: xfsnap install $host"
  else echo "peer is newer — update here: xfsnap upgrade"; fi
}

# run a command either locally (token LOCAL) or on a remote ssh host
at() {
  local host=$1; shift
  if [ "$host" = LOCAL ]; then eval "$*"; else ssh "${SSHOPTS[@]}" "$host" "$*"; fi
}
# file size in bytes (endpoint token LOCAL or an ssh name)
fsize() {
  local host=$1 pth=$2
  at "$host" "stat -c %s -- '$pth' 2>/dev/null || echo -1"
}

##############################################################################
# Config: flat key=value file, get/set/list/interview
##############################################################################
CFG_FILE=${XFSNAP_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/xfsnap/config}
declare -A CFG
declare -A CFG_KEYS=( [snapdir]=1 [incdir]=1 [peer]=1 [self]=1 [streams]=1 [chunk]=1 [full_interval]=1 [cipher]=1 [solana]=1 )
CFG_SNAPDIR= ; CFG_INCDIR= ; CFG_PEER= ; CFG_SELF=
declare -a SSHOPTS=()

cfg_valid_key() { [ -n "${CFG_KEYS[$1]:-}" ]; }

cfg_load() {
  CFG=()
  [ -f "$CFG_FILE" ] || return 0
  local line k v
  while IFS= read -r line || [ -n "$line" ]; do
    case $line in ''|'#'*) continue ;; esac
    [ -z "${line// /}" ] && continue
    k=${line%%=*}; v=${line#*=}
    k=${k## }; k=${k%% }
    [ -n "$k" ] && CFG[$k]=$v
  done < "$CFG_FILE"
}
cfg_get() { printf '%s\n' "${CFG[$1]:-}"; }
cfg_save() {
  mkdir -p "$(dirname "$CFG_FILE")"
  { printf '# xfsnap config (%s)\n' "$CFG_FILE"
    local k
    if (( ${#CFG[@]} )); then
      while IFS= read -r k; do printf '%s=%s\n' "$k" "${CFG[$k]}"; done \
        < <(printf '%s\n' "${!CFG[@]}" | sort)
    fi
  } > "$CFG_FILE"
}
cfg_set()   { cfg_valid_key "$1" || die "Unknown config key '$1' (valid: ${!CFG_KEYS[*]})"; CFG[$1]=$2; cfg_save; }
cfg_unset() { cfg_valid_key "$1" || die "Unknown config key '$1'"; unset 'CFG[$1]'; cfg_save; }
cfg_list() {
  [ -f "$CFG_FILE" ] && info "Config: $CFG_FILE" || info "Config: $CFG_FILE (not created yet)"
  local k
  if (( ${#CFG[@]} )); then
    while IFS= read -r k; do printf '  %-14s %s\n' "$k" "${CFG[$k]}"; done \
      < <(printf '%s\n' "${!CFG[@]}" | sort)
  fi
}

# turn config values into runtime settings (call after cfg_load)
cfg_apply() {
  local v
  v=$(cfg_get streams);       [ -n "$v" ] && STREAMS_DEFAULT=$v
  v=$(cfg_get chunk);         [ -n "$v" ] && CHUNK_DEFAULT=$(parse_size "$v")
  v=$(cfg_get full_interval); [ -n "$v" ] && FULL_INTERVAL=$v
  v=$(cfg_get cipher);        [ -n "$v" ] && CIPHER=$v
  v=$(cfg_get solana);        [ -n "$v" ] && SOLANA_BIN=$v
  STREAMS=$STREAMS_DEFAULT
  CHUNK=$CHUNK_DEFAULT
  CFG_SNAPDIR=$(cfg_get snapdir)
  CFG_INCDIR=$(cfg_get incdir)
  CFG_PEER=$(cfg_get peer)
  CFG_SELF=$(cfg_get self)
  SSHOPTS=(-o Compression=no -o ConnectTimeout=10 -o ServerAliveInterval=15 -c "$CIPHER")
}

# --- validator autodetect (Linux /proc) for `config interview` ---
# prints "<full_dir>\t<inc_dir>" or returns 1 if no validator found
detect_validator_dirs() {
  local pid
  pid=$(pgrep -x agave-validator 2>/dev/null | head -1)
  [ -n "$pid" ] || pid=$(pgrep -f 'agave-validator|solana-validator' 2>/dev/null | head -1)
  [ -n "$pid" ] && [ -r "/proc/$pid/cmdline" ] || return 1
  local -a args=()
  mapfile -d '' -t args < "/proc/$pid/cmdline"
  local full="" inc="" ledger="" i
  for (( i=0; i<${#args[@]}; i++ )); do
    case "${args[i]}" in
      --full-snapshot-archives-dir)        full="${args[i+1]:-}" ;;
      --incremental-snapshot-archives-dir) inc="${args[i+1]:-}" ;;
      --ledger|-l)                         ledger="${args[i+1]:-}" ;;
    esac
  done
  # archives default to the ledger root dir when the archive flags are unset
  [ -z "$full" ] && full=$ledger
  [ -z "$inc" ]  && inc=$full
  [ -n "$full" ] || return 1
  printf '%s\t%s\n' "$full" "$inc"
}

_ask() {  # prompt default -> answer on stdout (default kept if empty)
  local p=$1 d=$2 ans
  if [ -n "$d" ]; then printf '%s [%s]: ' "$p" "$d" >&2; else printf '%s: ' "$p" >&2; fi
  read -r ans || true            # default IFS trims leading/trailing whitespace
  printf '%s\n' "${ans:-$d}"
}
_ask_yn() {  # prompt [default Y|N] -> return 0 for yes
  local p=$1 d=${2:-Y} ans
  if [ "$d" = Y ]; then printf '%s [Y/n]: ' "$p" >&2; else printf '%s [y/N]: ' "$p" >&2; fi
  read -r ans || true
  ans=${ans:-$d}
  case $ans in [yY]*) return 0 ;; *) return 1 ;; esac
}
# install xfsnap on a host, then run its interview interactively (over ssh -t).
# XFSNAP_NO_WIZARD stops the remote interview from recursing into its own wizard.
_setup_host() {
  local h=$1
  step "Setting up '$h' (install + interview)"
  do_install_remote "$h" || { warn "Install on '$h' failed; skipping"; return 1; }
  ssh -t "${SSHOPTS[@]}" "$h" "XFSNAP_NO_WIZARD=1 xfsnap config interview" \
    || warn "Remote interview on '$h' did not complete"
}

do_interview() {
  step "xfsnap setup ($CFG_FILE)"
  local sd="" id="" det
  if det=$(detect_validator_dirs); then
    IFS=$'\t' read -r sd id <<< "$det"
    info "Detected running validator snapshot dirs:"
    info "  full snapshots: $sd"
    info "  incrementals:   $id"
  else
    info "No running validator detected on this host."
    if _ask_yn "Is this an orchestrator-only box (holds no snapshots, only runs 'transfer')?" N; then
      info "Orchestrator-only — nothing to configure here; just use: xfsnap transfer SRC DST"
      return 0
    fi
  fi
  local defsd=${sd:-$(cfg_get snapdir)}
  sd=$(_ask "Full snapshot dir" "$defsd")
  [ -n "$sd" ] || die "A full snapshot dir is required"
  local defid=${id:-$(cfg_get incdir)}; [ -n "$defid" ] || defid=$sd
  id=$(_ask "Incremental dir" "$defid")
  local peer self
  peer=$(_ask "Default peer's ssh short name (Enter to skip)" "$(cfg_get peer)")
  self=$(_ask "This host's own ssh short name (optional, speeds up 'transfer')" "$(cfg_get self)")

  [ -d "$sd" ] || warn "Snapshot dir does not exist yet: $sd"
  if [ -n "$peer" ]; then
    if ssh -o ConnectTimeout=8 -o BatchMode=yes "$peer" true 2>/dev/null; then
      ok "ssh '$peer' reachable"
      if ssh -o ConnectTimeout=8 -o BatchMode=yes "$peer" 'command -v xfsnap >/dev/null 2>&1'; then
        ok "xfsnap present on '$peer'"
      else
        warn "xfsnap not found on '$peer' -- install it there too (copy this file, run: xfsnap install)"
      fi
    else
      warn "Cannot ssh '$peer' non-interactively; check ~/.ssh/config and keys"
    fi
  fi

  cfg_set snapdir "$sd"
  cfg_set incdir  "$id"
  if [ -n "$peer" ]; then cfg_set peer "$peer"
  elif [ -n "${CFG[peer]:-}" ]; then cfg_unset peer; fi
  [ -n "$self" ] && cfg_set self "$self"
  ok "Wrote $CFG_FILE"
  cfg_list

  # guided multi-host wizard: offer to set up the peer + any other hosts from
  # here. Interactive only (needs a real terminal); skipped when scripted or
  # when invoked by another host's wizard (XFSNAP_NO_WIZARD).
  if [ -t 0 ] && [ -z "${XFSNAP_NO_WIZARD:-}" ]; then
    if [ -n "$peer" ] && _ask_yn "Also set up peer '$peer' now (install xfsnap there + run its setup)?" Y; then
      _setup_host "$peer"
    fi
    local more
    while true; do
      more=$(_ask "Set up another host? ssh name (Enter to finish)" "")
      [ -n "$more" ] || break
      _setup_host "$more"
    done
    ok "Setup complete — try: xfsnap doctor"
  fi
}

# run the interview on a remote host over ssh (interactive, incl. its wizard).
# Syncs the host to our version first: install if missing, upgrade if older;
# leave it alone if it's already current or newer (never downgrade).
do_interview_remote() {
  local host=$1 pv cmp
  ssh "${SSHOPTS[@]}" "$host" true 2>/dev/null || die "Cannot ssh '$host' (check ~/.ssh/config and keys)"
  pv=$(ssh "${SSHOPTS[@]}" "$host" 'command -v xfsnap >/dev/null 2>&1 && xfsnap version' 2>/dev/null | awk '{print $2}')
  if [ -z "$pv" ]; then
    info "xfsnap not on '$host' yet — installing $VERSION first"
    do_install_remote "$host"
  else
    cmp=$(ver_cmp "$VERSION" "$pv")
    if [ "$cmp" = 1 ]; then
      warn "'$host' runs older xfsnap $pv (you have $VERSION)"
      if _ask_yn "Upgrade '$host' to $VERSION first?" Y; then do_install_remote "$host"
      else info "Leaving '$host' on $pv"; fi
    elif [ "$cmp" = -1 ]; then
      info "'$host' runs $pv (newer than your $VERSION) — leaving its version as-is"
    fi
  fi
  step "Running interview on '$host' over ssh"
  ssh -t "${SSHOPTS[@]}" "$host" "xfsnap config interview"
}

do_config() {
  local sub=${1:-list}; [ $# -gt 0 ] && shift || true
  case $sub in
    get)        [ -n "${1:-}" ] || die "Usage: xfsnap config get <key>"; cfg_get "$1" ;;
    set)        [ -n "${1:-}" ] && [ $# -ge 2 ] || die "Usage: xfsnap config set <key> <value>"; cfg_set "$1" "$2"; ok "Set $1=$2" ;;
    unset)      [ -n "${1:-}" ] || die "Usage: xfsnap config unset <key>"; cfg_unset "$1"; ok "Unset $1" ;;
    list|"")    cfg_list ;;
    path)       printf '%s\n' "$CFG_FILE" ;;
    interview)  if [ -n "${1:-}" ]; then do_interview_remote "$1"; else do_interview; fi ;;
    *)          die "Config subcommands: get | set | unset | list | path | interview" ;;
  esac
}

##############################################################################
# Endpoint resolution (self-describing nodes)
##############################################################################
FROM_HOST=      # set via internal --_from marker when a transfer hops to source
declare -A DIRCACHE

# token for a user-facing ssh name: LOCAL if it's this box, else the name.
# LOCAL_SELF is the sentinel used by bare put/get for "this box".
ep_token() {
  local name=$1
  if   [ "$name" = LOCAL_SELF ]; then echo LOCAL
  elif [ -n "$FROM_HOST" ] && [ "$name" = "$FROM_HOST" ]; then echo LOCAL
  elif [ -n "$CFG_SELF" ]  && [ "$name" = "$CFG_SELF" ];  then echo LOCAL
  else echo "$name"; fi
}

# resolve snapdir/incdir for an endpoint. token=LOCAL uses local config;
# otherwise ask the remote host for its own config over ssh. Prints the dir on
# stdout; on failure prints a hint to stderr and returns 1 (callers must check --
# a `die` here wouldn't stop the script since we're run in $(...)).
ep_dir() {
  local name=$1 token=$2 kind=$3   # kind: snapdir | incdir
  if [ "$token" = LOCAL ]; then
    local v; v=$(cfg_get "$kind")
    [ -n "$v" ] || { bad "No '$kind' configured on this host -> run: xfsnap config interview"; return 1; }
    printf '%s\n' "$v"
  else
    local ck="$name/$kind"
    if [ -n "${DIRCACHE[$ck]:-}" ]; then printf '%s\n' "${DIRCACHE[$ck]}"; return 0; fi
    local v; v=$(ssh "${SSHOPTS[@]}" "$name" "xfsnap config get $kind" 2>/dev/null)
    if [ -z "$v" ]; then
      if ssh "${SSHOPTS[@]}" "$name" 'command -v xfsnap >/dev/null 2>&1'; then
        bad "Peer '$name' has xfsnap but no '$kind' configured -> run: ssh $name xfsnap config interview"
      else
        bad "xfsnap not installed (or not in PATH) on peer '$name' -> install it there (see 'xfsnap doctor')"
      fi
      return 1
    fi
    DIRCACHE[$ck]=$v
    printf '%s\n' "$v"
  fi
}

##############################################################################
# Snapshot discovery  (list dir + filter locally; no remote globbing)
##############################################################################
newest_full() {
  local host=$1 dir=$2 b slot
  at "$host" "ls -1 '$dir' 2>/dev/null" | \
    while IFS= read -r b; do
      case $b in snapshot-*.tar.zst) ;; *) continue ;; esac
      slot=${b#snapshot-}; slot=${slot%%-*}
      [[ $slot =~ ^[0-9]+$ ]] && printf '%s %s\n' "$slot" "$b"
    done | sort -n -k1,1 | tail -1 | cut -d' ' -f2-
}
newest_inc() {
  local host=$1 dir=$2 b rest base tip
  at "$host" "ls -1 '$dir' 2>/dev/null" | \
    while IFS= read -r b; do
      case $b in incremental-snapshot-*.tar.zst) ;; *) continue ;; esac
      rest=${b#incremental-snapshot-}
      base=${rest%%-*}
      tip=${rest#*-}; tip=${tip%%-*}
      [[ $base =~ ^[0-9]+$ && $tip =~ ^[0-9]+$ ]] && printf '%s %s\n' "$tip" "$b"
    done | sort -n -k1,1 | tail -1 | cut -d' ' -f2-
}
full_slot() { local b=$1; b=${b#snapshot-}; echo "${b%%-*}"; }
inc_base()  { local b=$1; b=${b#incremental-snapshot-}; echo "${b%%-*}"; }
inc_tip()   { local b=$1; b=${b#incremental-snapshot-}; b=${b#*-}; echo "${b%%-*}"; }

current_slot() {
  if [ -n "${XFSNAP_NOW_SLOT:-}" ]; then echo "$XFSNAP_NOW_SLOT"; return 0; fi
  local s
  s=$("$SOLANA_BIN" slot 2>/dev/null) || return 1
  [[ $s =~ ^[0-9]+$ ]] && { echo "$s"; return 0; } || return 1
}

##############################################################################
# Pre-snapshot timing guard (full snapshots only). 0 = proceed, 1 = abort.
##############################################################################
guard_full() {
  local snapslot=$1 assume_yes=$2 now
  if ! now=$(current_slot); then
    warn "Couldn't get current slot ('$SOLANA_BIN slot'); skipping timing guard"
    return 0
  fi
  local next=$(( snapslot + FULL_INTERVAL ))
  (( now >= next )) && next=$(( ( now / FULL_INTERVAL + 1 ) * FULL_INTERVAL ))
  local slots_left=$(( next - now ))
  local secs_left=$(( slots_left * 2 / 5 ))   # ~0.4s/slot
  info "Current slot $now, this snapshot slot $snapslot"
  info "Next full snapshot ~slot $next ($slots_left slots, ~$(hms $secs_left) away)"
  if (( secs_left < GUARD_SECONDS )); then
    warn "A new full snapshot is due in ~$(hms $secs_left) (< $(hms $GUARD_SECONDS))."
    warn "It may be better to wait for it than to ship this soon-to-be-stale one."
    if [ "$assume_yes" = 1 ]; then warn "--yes given, proceeding anyway."; return 0; fi
    printf 'Proceed anyway? [y/N] ' >&2
    local ans; read -r ans || true
    case $ans in [yY]*) return 0 ;; *) return 1 ;; esac
  fi
  return 0
}

##############################################################################
# The transfer engine.  xfer <SRC_TOK> <SRC_PATH> <DST_TOK> <DST_DIR> <NAME>
# Exactly one of SRC_TOK / DST_TOK is LOCAL (the box running this).
##############################################################################
STREAMS=$STREAMS_DEFAULT
CHUNK=$CHUNK_DEFAULT
OPT_YES=0; OPT_VERIFY=0; OPT_NOVERIFY=0; OPT_DRY=0

xfer() {
  local SRC_EP=$1 SRC_PATH=$2 DST_EP=$3 DST_DIR=$4 NAME=$5
  local FINAL="$DST_DIR/$NAME"
  local PART="$DST_DIR/.xfsnap/$NAME.part"
  local LEDGER="$DST_DIR/.xfsnap/$NAME.state"
  local STATEDIR="$DST_DIR/.xfsnap"

  local SIZE; SIZE=$(fsize "$SRC_EP" "$SRC_PATH")
  (( SIZE > 0 )) || die "Source file missing or empty: $SRC_PATH"

  local CHUNKS=$(( (SIZE + CHUNK - 1) / CHUNK ))
  step "Transfer ${C_BLD}$NAME${C_RST}  $(human "$SIZE")  ($CHUNKS chunks x $(human "$CHUNK"), $STREAMS streams)"
  info "src ${SRC_EP}:$SRC_PATH  ->  dst ${DST_EP}:$FINAL"

  if (( OPT_DRY )); then info "Dry-run: nothing transferred"; return 0; fi

  at "$DST_EP" "mkdir -p '$DST_DIR' '$STATEDIR'"

  # ---- resume: consistent ledger + part to continue? ----
  local -A DONE=()
  local hdr have_part reuse=0 line
  hdr=$(at "$DST_EP" "head -1 '$LEDGER' 2>/dev/null || true")
  have_part=$(fsize "$DST_EP" "$PART")
  if [[ $hdr == "# xfsnap size=$SIZE chunk=$CHUNK"* ]] && (( have_part == SIZE )); then
    reuse=1
    while IFS= read -r line; do
      case $line in '#'*|'') continue ;; esac
      DONE[$line]=1
    done < <(at "$DST_EP" "cat '$LEDGER' 2>/dev/null || true")
    info "Resuming: ${#DONE[@]} / $CHUNKS chunks already done"
  fi
  if (( ! reuse )); then
    at "$DST_EP" "rm -f '$PART' '$LEDGER'; truncate -s $SIZE '$PART'; printf '# xfsnap size=%s chunk=%s name=%s\n' $SIZE $CHUNK '$NAME' > '$LEDGER'"
  fi

  # ---- pending chunk list ----
  local -a pending=(); local i
  for (( i=0; i<CHUNKS; i++ )); do
    [ -n "${DONE[$i]:-}" ] || pending+=("$i")
  done
  local base_done=$(( CHUNKS - ${#pending[@]} ))
  if (( ${#pending[@]} == 0 )); then
    info "All chunks already present"
  else
    local scratch; scratch=$(mktemp -d "${TMPDIR:-/tmp}/xfsnap.XXXXXX")
    local donef="$scratch/done" failf="$scratch/fail"
    : > "$donef"; : > "$failf"
    local t0=$SECONDS
    local last_prog=-100

    # The RECEIVER marks a chunk done only if it wrote exactly 'len' bytes, so a
    # SIGKILLed sender (clean EOF -> writer exits 0 with partial data) can't
    # record a partial chunk as complete; it's redone on resume (conv=notrunc
    # keeps the other chunks intact).
    _chunk() {
      local idx=$1
      local off=$(( idx * CHUNK ))
      local len=$(( SIZE - off )); (( len > CHUNK )) && len=$CHUNK
      local rd="dd if='$SRC_PATH' bs=$DD_BS skip=$off count=$len iflag=skip_bytes,count_bytes status=none"
      local wr="n=\$(dd of='$PART' bs=$DD_BS seek=$off oflag=seek_bytes conv=notrunc 2>&1 | awk '/ bytes /{print \$1; exit}'); [ \"\$n\" = \"$len\" ] && printf '%s\n' $idx >> '$LEDGER'"
      if [ "$SRC_EP" = LOCAL ]; then
        eval "$rd" | ssh "${SSHOPTS[@]}" "$DST_EP" "$wr"
      else
        ssh "${SSHOPTS[@]}" "$SRC_EP" "$rd" | eval "$wr"
      fi
      if [ $? -eq 0 ]; then printf '%s\n' "$idx" >> "$donef"
      else printf '%s\n' "$idx" >> "$failf"; fi
    }

    _bar() {
      local dn=$1 total=$2 elapsed=$3
      local pct=$(( total>0 ? dn*100/total : 100 ))
      local width=28
      local filled=$(( pct*width/100 ))
      local bar="" j
      for (( j=0; j<width; j++ )); do (( j<filled )) && bar+='#' || bar+='-'; done
      local bytes=$(( dn*CHUNK )); (( bytes>SIZE )) && bytes=$SIZE
      local rate=0 eta=0
      (( elapsed>0 )) && rate=$(( bytes/elapsed ))
      (( rate>0 )) && eta=$(( (SIZE-bytes)/rate ))
      if (( PROG_TTY )); then
        printf '\r%s[%s] %3d%%  %d/%d  %s/s  ETA %s%s' \
          "$C_DIM" "$bar" "$pct" "$dn" "$total" "$(human "$rate")" "$(hms $eta)" "$C_RST" >&2
      elif (( SECONDS - last_prog >= 5 || dn >= total )); then
        last_prog=$SECONDS
        printf '  %3d%%  %d/%d chunks  %s/s  ETA %s\n' \
          "$pct" "$dn" "$total" "$(human "$rate")" "$(hms $eta)" >&2
      fi
    }

    _completed() { echo $(( $(wc -l < "$donef") + $(wc -l < "$failf") )); }

    local launched=0 npend=${#pending[@]}
    for i in "${pending[@]}"; do
      while (( launched - $(_completed) >= STREAMS )); do
        _bar $(( base_done + $(wc -l < "$donef") )) "$CHUNKS" $(( SECONDS - t0 )); sleep 0.1
      done
      _chunk "$i" &
      (( ++launched ))
    done
    while (( $(_completed) < npend )); do
      _bar $(( base_done + $(wc -l < "$donef") )) "$CHUNKS" $(( SECONDS - t0 )); sleep 0.1
    done
    wait
    _bar $(( base_done + $(wc -l < "$donef") )) "$CHUNKS" $(( SECONDS - t0 )); printf '\n' >&2

    local nfail; nfail=$(wc -l < "$failf")
    rm -rf "$scratch"
    if (( nfail > 0 )); then
      warn "$nfail chunk(s) failed; ledger preserved. re-run the same command to resume."
      return 1
    fi
  fi

  # ---- finalize: unique completed indices must cover every chunk ----
  local ndone
  ndone=$(at "$DST_EP" "grep '^[0-9]' '$LEDGER' 2>/dev/null | sort -un | wc -l")
  if (( ndone < CHUNKS )); then
    warn "Only $ndone/$CHUNKS chunks confirmed in ledger; re-run to resume."
    return 1
  fi

  if (( OPT_VERIFY )); then
    step "Verifying source vs dest checksum (sha256)"
    local ssum dsum
    ssum=$(at "$SRC_EP" "sha256sum -- '$SRC_PATH'" | cut -d' ' -f1)
    dsum=$(at "$DST_EP" "sha256sum -- '$PART'"     | cut -d' ' -f1)
    [ "$ssum" = "$dsum" ] || die "Checksum mismatch! src=$ssum dst=$dsum (ledger kept)"
    ok "sha256 match ($ssum)"
  fi

  at "$DST_EP" "mv -f '$PART' '$FINAL'"

  if (( ! OPT_NOVERIFY )); then
    step "zstd integrity test on dest"
    if at "$DST_EP" "zstd -t -- '$FINAL'" >/dev/null 2>&1; then ok "zstd -t passed"
    else die "zstd -t failed on dest: $FINAL"; fi
  fi

  at "$DST_EP" "rm -f '$LEDGER'"
  ok "Delivered ${DST_EP}:$FINAL"
}

##############################################################################
# High-level operations
##############################################################################
run_full() {
  local S_TOK=$1 S_NAME=$2 D_TOK=$3 D_NAME=$4
  local sdir ddir
  sdir=$(ep_dir "$S_NAME" "$S_TOK" snapdir) || return 1
  ddir=$(ep_dir "$D_NAME" "$D_TOK" snapdir) || return 1
  local name; name=$(newest_full "$S_TOK" "$sdir")
  [ -n "$name" ] || die "No full snapshot found in ${S_NAME:-here}:$sdir"
  if [ "$S_TOK" = LOCAL ]; then guard_full "$(full_slot "$name")" "$OPT_YES" || die "Aborted by timing guard"; fi
  xfer "$S_TOK" "$sdir/$name" "$D_TOK" "$ddir" "$name"
}

run_inc() {
  local S_TOK=$1 S_NAME=$2 D_TOK=$3 D_NAME=$4
  local sdir ddir dsnap
  sdir=$(ep_dir "$S_NAME" "$S_TOK" incdir)   || return 1
  ddir=$(ep_dir "$D_NAME" "$D_TOK" incdir)   || return 1
  dsnap=$(ep_dir "$D_NAME" "$D_TOK" snapdir)  || return 1

  _ship_one_inc() {
    local nm=$1 base basefull
    base=$(inc_base "$nm")
    basefull=$(at "$D_TOK" "ls -1 '$dsnap' 2>/dev/null" | grep -E "^snapshot-$base-.*\.tar\.zst$" | head -1)
    if [ -z "$basefull" ]; then
      warn "Dest is missing the base full snapshot for slot $base"
      warn "The incremental won't be usable until that full is present; shipping anyway."
    fi
    xfer "$S_TOK" "$sdir/$nm" "$D_TOK" "$ddir" "$nm"
  }

  local last; last=$(newest_inc "$S_TOK" "$sdir")
  local last_tip=0; [ -n "$last" ] && last_tip=$(inc_tip "$last")

  if (( OPT_NOW )); then
    if [ -n "$last" ]; then
      step "Shipping current newest incremental now: $last"
      if (( OPT_WATCH )); then _ship_one_inc "$last" || warn "Ship failed, will retry on next one"
      else _ship_one_inc "$last"; return $?; fi
    else
      info "No incremental present yet; waiting for the next one"
    fi
  fi

  local cur tip
  if (( OPT_WATCH )); then
    step "Watching ${S_NAME:-here}:$sdir for new incrementals (Ctrl-C to stop)"
    info "Baseline: ${last:-<none>} (tip $last_tip)"
    while true; do
      cur=$(newest_inc "$S_TOK" "$sdir"); tip=0; [ -n "$cur" ] && tip=$(inc_tip "$cur")
      if (( tip > last_tip )); then
        last_tip=$tip; step "New incremental: $cur"
        _ship_one_inc "$cur" || warn "Ship failed, will retry on next one"
      fi
      sleep 2
    done
  else
    step "Waiting for the next incremental after ${last:-<none>} ..."
    while true; do
      cur=$(newest_inc "$S_TOK" "$sdir"); tip=0; [ -n "$cur" ] && tip=$(inc_tip "$cur")
      if (( tip > last_tip )); then
        step "New incremental: $cur"; _ship_one_inc "$cur"; return $?
      fi
      sleep 2
    done
  fi
}

# warn (or, with --strict, abort) if a remote host runs a different xfsnap version
check_peer_version() {
  local host=$1 pv
  pv=$(ssh "${SSHOPTS[@]}" "$host" 'xfsnap version' 2>/dev/null | awk '{print $2}')
  [ -n "$pv" ] || return 0
  [ "$pv" = "$VERSION" ] && return 0
  local hint; hint=$(ver_hint "$host" "$pv")
  if (( OPT_STRICT )); then
    die "Version mismatch with '$host': here $VERSION, there $pv (--strict) — $hint"
  fi
  warn "Version skew: here $VERSION, '$host' $pv — $hint"
}

# dispatch a full/inc op given user names; hop to source if neither end is local
do_op() {
  local kind=$1 A=$2 B=$3
  local aname=$A bname=$B
  [ "$A" = LOCAL_SELF ] && aname=
  [ "$B" = LOCAL_SELF ] && bname=
  local at_ bt_; at_=$(ep_token "$A"); bt_=$(ep_token "$B")
  if [ "$at_" = LOCAL ] || [ "$bt_" = LOCAL ]; then
    [ "$at_" != LOCAL ] && check_peer_version "$at_"
    [ "$bt_" != LOCAL ] && check_peer_version "$bt_"
    if [ "$kind" = full ]; then run_full "$at_" "$aname" "$bt_" "$bname"
    else                        run_inc  "$at_" "$aname" "$bt_" "$bname"; fi
  else
    # we're about to run xfsnap ON the source with flags we chose, so the
    # source must be able to understand them -- this is where skew matters most.
    check_peer_version "$A"
    local verb; [ "$kind" = full ] && verb=transfer || verb=transferinc
    step "Neither endpoint is local; hopping to '$A' to run the transfer there"
    ssh "${SSHOPTS[@]}" "$A" "xfsnap $verb $A $B --_from $A ${FWD_OPTS[*]:-}"
  fi
}

do_clean() {
  local d cnt=0 freed=0 f sz
  local -a dirs=()
  [ -n "$CFG_SNAPDIR" ] && dirs+=("$CFG_SNAPDIR")
  [ -n "$CFG_INCDIR" ] && [ "$CFG_INCDIR" != "$CFG_SNAPDIR" ] && dirs+=("$CFG_INCDIR")
  (( ${#dirs[@]} )) || die "No snapdir/incdir configured; run: xfsnap config interview"
  shopt -s nullglob
  for d in "${dirs[@]}"; do
    [ -d "$d/.xfsnap" ] || continue
    for f in "$d"/.xfsnap/*.part "$d"/.xfsnap/*.state; do
      sz=$(stat -c %s -- "$f" 2>/dev/null || echo 0)
      freed=$(( freed + sz )); cnt=$(( cnt + 1 ))
      info "Removing $f"; rm -f -- "$f"
    done
  done
  shopt -u nullglob
  ok "Cleaned $cnt staging file(s), freed ~$(human "$freed")"
}

# verify this host + its peer are ready to transfer
do_check() {
  local peer=${1:-$CFG_PEER}
  step "xfsnap $VERSION doctor"
  info "Config: $CFG_FILE"
  local problems=0 k v
  for k in snapdir incdir; do
    v=$(cfg_get "$k")
    if [ -z "$v" ]; then bad "Local '$k' not set   ->  xfsnap config set $k <dir>"; problems=$(( problems + 1 ))
    elif [ -d "$v" ]; then ok "Local $k = $v"
    else warn "Local $k = $v   (directory does not exist yet)"; fi
  done
  if [ -z "$peer" ]; then
    warn "No peer configured   ->  xfsnap config set peer <sshname>   (needed for bare put/get)"
  else
    info "Peer: $peer"
    if ssh -o ConnectTimeout=8 -o BatchMode=yes "$peer" true 2>/dev/null; then
      ok "ssh '$peer' reachable"
      local pv
      if pv=$(ssh -o ConnectTimeout=8 -o BatchMode=yes "$peer" 'command -v xfsnap >/dev/null 2>&1 && xfsnap version' 2>/dev/null) && [ -n "$pv" ]; then
        ok "'$peer' has $pv"
        local pvn=${pv##* }
        if [ "$pvn" != "$VERSION" ]; then
          warn "Version skew: here $VERSION, '$peer' $pvn — $(ver_hint "$peer" "$pvn")"
          (( OPT_STRICT )) && problems=$(( problems + 1 ))
        fi
        local psd; psd=$(ssh -o ConnectTimeout=8 -o BatchMode=yes "$peer" 'xfsnap config get snapdir' 2>/dev/null)
        if [ -n "$psd" ]; then ok "'$peer' snapdir = $psd"
        else bad "'$peer' has xfsnap but is not configured   ->  ssh $peer xfsnap config interview"; problems=$(( problems + 1 )); fi
      else
        bad "xfsnap not installed on '$peer'   ->  install it there (copy the file, run: xfsnap install)"; problems=$(( problems + 1 ))
      fi
    else
      bad "Cannot ssh '$peer' non-interactively   ->  check ~/.ssh/config and keys"; problems=$(( problems + 1 ))
    fi
  fi
  (( problems == 0 )) && ok "Ready to transfer" || die "$problems problem(s) found — see above"
}

# atomically place SRC at TARGET: copy to a temp in TARGET's dir, then rename.
# The rename gives TARGET a fresh inode, so an xfsnap upgrading ITSELF isn't
# corrupted mid-run -- bash reads a script incrementally by byte offset, so
# overwriting the running file in place (cp) makes it read garbage past that point.
_place_file() {
  local src=$1 target=$2 dir
  dir=$(dirname "$target")
  local SUDO=; [ -w "$dir" ] || SUDO=sudo
  [ -z "$SUDO" ] || info "Using sudo to write $target"
  local tmp="$target.new.$$"
  # No `--`: BSD chmod (macOS) treats it as a filename. Our paths never start
  # with `-`, so it guards nothing. Explicit 0755 (not `+x`): the source may be
  # a mode-0600 mktemp file, and `+x` on that yields root-only 0700.
  $SUDO cp -f "$src" "$tmp"    || { $SUDO rm -f "$tmp"; die "Write to $dir failed"; }
  $SUDO chmod 0755 "$tmp"      || { $SUDO rm -f "$tmp"; die "chmod failed"; }
  $SUDO mv -f "$tmp" "$target" || { $SUDO rm -f "$tmp"; die "Install to $target failed"; }
}

do_install() {
  local prefix=${1:-/usr/local/bin}
  [ -f "$SCRIPT_PATH" ] || die "Run xfsnap as a file to install it (got path=$SCRIPT_PATH)"
  _place_file "$SCRIPT_PATH" "$prefix/xfsnap"
  ok "Installed xfsnap $VERSION -> $prefix/xfsnap"
}

# download the latest xfsnap from GitHub and replace this install in place.
# XFSNAP_SRC=/path installs from a local file instead (testing / air-gapped).
do_upgrade() {
  local target=$SCRIPT_PATH
  [ -f "$target" ] || die "Can't locate my own file to upgrade (run xfsnap as a file)"
  local url="https://raw.githubusercontent.com/$XFSNAP_REPO/$XFSNAP_BRANCH/xfsnap"
  local tmp; tmp=$(mktemp)
  if [ -n "${XFSNAP_SRC:-}" ]; then
    step "Upgrading from local $XFSNAP_SRC (have $VERSION)"
    cp -f "$XFSNAP_SRC" "$tmp" || { rm -f "$tmp"; die "Copy from $XFSNAP_SRC failed"; }
  else
    step "Fetching latest xfsnap (have $VERSION) from $XFSNAP_REPO@$XFSNAP_BRANCH"
    if command -v curl >/dev/null 2>&1; then curl -fsSL "$url" -o "$tmp" || { rm -f "$tmp"; die "Download failed ($url)"; }
    elif command -v wget >/dev/null 2>&1; then wget -qO "$tmp" "$url" || { rm -f "$tmp"; die "Download failed ($url)"; }
    else rm -f "$tmp"; die "Need curl or wget to upgrade"; fi
  fi
  head -n 3 "$tmp" | grep -q xfsnap || { rm -f "$tmp"; die "Downloaded file doesn't look like xfsnap"; }
  local newver; newver=$(bash "$tmp" version 2>/dev/null | awk '{print $2}')
  if [ -n "$newver" ] && [ "$newver" = "$VERSION" ]; then
    rm -f "$tmp"; ok "Already up to date ($VERSION)"; return 0
  fi
  _place_file "$tmp" "$target"
  rm -f "$tmp"
  ok "Upgraded $VERSION -> ${newver:-?}  ($target)"
  [ -n "$CFG_PEER" ] && info "Peer '$CFG_PEER' upgrades separately — sync with: xfsnap install $CFG_PEER"
  return 0
}

# copy this file to another host and install it there (sudo if needed)
do_install_remote() {
  local host=$1 prefix=${2:-/usr/local/bin}
  local src=$SCRIPT_PATH
  [ -f "$src" ] || die "Can't find my own file to send (run xfsnap as a file)"
  step "Installing xfsnap $VERSION on '$host' -> $prefix"
  ssh "${SSHOPTS[@]}" "$host" true 2>/dev/null || die "Cannot ssh '$host' (check ~/.ssh/config and keys)"
  # this pushes OUR version; refuse to silently downgrade a newer peer
  local pv; pv=$(ssh "${SSHOPTS[@]}" "$host" 'command -v xfsnap >/dev/null 2>&1 && xfsnap version' 2>/dev/null | awk '{print $2}')
  if [ -n "$pv" ] && [ "$(ver_cmp "$pv" "$VERSION")" = 1 ] && [ "$OPT_FORCE" != 1 ]; then
    die "'$host' already has newer xfsnap $pv (you have $VERSION); refusing to downgrade — run 'xfsnap upgrade' here first, or pass --force"
  fi
  local tmp="/tmp/xfsnap.install.$$"
  scp -q "${SSHOPTS[@]}" "$src" "$host:$tmp" || die "scp to '$host' failed"
  ssh "${SSHOPTS[@]}" "$host" "bash '$tmp' install '$prefix'; rc=\$?; rm -f '$tmp'; exit \$rc" \
    || die "Remote install on '$host' failed"
  info "Next: ssh $host xfsnap config interview"
}

##############################################################################
# Usage
##############################################################################
usage() {
  cat >&2 <<EOF
xfsnap $VERSION — Fast, resumable Solana snapshot transfer between hosts

USAGE
  xfsnap <subcommand> [options]

TRANSFER (aliases)   ([PEER] overrides the configured default peer)
  get   g   [PEER]           Pull newest full snapshot: peer -> here
  getinc  gi [PEER]          Pull newest incremental:   peer -> here
  put   p   [PEER]           Push newest full snapshot: here -> peer
  putinc  pi [PEER]          Push newest incremental:   here -> peer
  transfer  trf  SRC DST     Push newest full        SRC -> DST (ssh short names)
  transferinc trfi SRC DST   Push newest incremental SRC -> DST
  clean  cl                  Remove leftover .xfsnap staging on this host

SETUP
  interview [HOST]           Interactive setup — here, or on a remote ssh HOST
                             (installs HOST if missing; asks before upgrading it)
  config get|set|unset KEY   Read/write config ($CFG_FILE)
  config list | path         Show config
  doctor (check) [PEER]      Verify this host + peer are ready to transfer
  install [PREFIX]           Install here (PREFIX default /usr/local/bin)
  install HOST [PREFIX]      Copy this file to a remote ssh HOST and install it
  upgrade                    Download + install the latest xfsnap from GitHub
  version (-V) | help (h)

OPTIONS
  --streams N     Concurrent streams (default $STREAMS_DEFAULT)
  --chunk SIZE    Chunk size, e.g. 512M, 2G (default $(human "$CHUNK_DEFAULT"))
  --yes           Assume yes to the pre-snapshot timing guard
  --no-verify     Skip the final zstd -t on the dest
  --verify        Also sha256 the whole file end-to-end (slow)
  --watch         Loop, shipping each new incremental (putinc/getinc)
  --now           Ship the current newest now, don't wait (putinc/getinc)
  --strict        Abort (don't just warn) if the peer's xfsnap version differs
  --force         Push our version even if the peer's is newer (install HOST)
  --dry-run       Show the plan only

Each host describes only itself (snapdir/incdir/peer) via 'xfsnap config';
the source discovers a destination's dirs by asking it over ssh.
EOF
}

##############################################################################
# Arg parsing / dispatch
##############################################################################
OPT_WATCH=0
OPT_NOW=0
OPT_STRICT=0
OPT_FORCE=0
declare -a FWD_OPTS=()
declare -a POSARGS=()

parse_common_opts() {
  local -a rest=()
  while (( $# )); do
    case $1 in
      --streams)   STREAMS=$2; FWD_OPTS+=(--streams "$2"); shift 2 ;;
      --chunk)     CHUNK=$(parse_size "$2"); FWD_OPTS+=(--chunk "$2"); shift 2 ;;
      --yes|-y)    OPT_YES=1; FWD_OPTS+=(--yes); shift ;;
      --no-verify) OPT_NOVERIFY=1; FWD_OPTS+=(--no-verify); shift ;;
      --verify)    OPT_VERIFY=1; FWD_OPTS+=(--verify); shift ;;
      --watch)     OPT_WATCH=1; FWD_OPTS+=(--watch); shift ;;
      --now)       OPT_NOW=1; FWD_OPTS+=(--now); shift ;;
      --strict)    OPT_STRICT=1; FWD_OPTS+=(--strict); shift ;;
      --force)     OPT_FORCE=1; FWD_OPTS+=(--force); shift ;;
      --dry-run)   OPT_DRY=1; FWD_OPTS+=(--dry-run); shift ;;
      --_from)     FROM_HOST=$2; shift 2 ;;   # internal hop marker (not forwarded)
      --)          shift; rest+=("$@"); break ;;
      -*)          die "Unknown option: $1" ;;
      *)           rest+=("$1"); shift ;;
    esac
  done
  POSARGS=("${rest[@]}")
}

main() {
  cfg_load
  cfg_apply
  if (( $# == 0 )); then
    usage
    [ -f "$CFG_FILE" ] || printf '\n%sFirst run?%s  get started with:  xfsnap config interview\n' "$C_BLD" "$C_RST" >&2
    exit 1
  fi
  local cmd=$1 peer; shift
  parse_common_opts "$@"

  case $cmd in
    help|h|-h|--help)         usage ;;
    version|--version|-V|-v)  printf 'xfsnap %s\n' "$VERSION" ;;
    config|cfg)        do_config "${POSARGS[@]}" ;;
    interview)         if [ -n "${POSARGS[0]:-}" ]; then do_interview_remote "${POSARGS[0]}"; else do_interview; fi ;;
    install)
      case ${POSARGS[0]:-} in
        '')    do_install "" ;;                                        # local, default prefix
        */*)   do_install "${POSARGS[0]}" ;;                           # a path -> local prefix
        *)     do_install_remote "${POSARGS[0]}" "${POSARGS[1]:-}" ;;  # an ssh host -> remote
      esac ;;

    put|p|get|g|putinc|pi|getinc|gi)
      # optional explicit peer overrides the configured default
      peer=${POSARGS[0]:-$CFG_PEER}
      [ -n "$peer" ] || die "No peer — pass one (e.g. 'xfsnap $cmd <host>') or set a default: xfsnap config set peer <host>"
      case $cmd in
        put|p)     do_op full LOCAL_SELF "$peer" ;;
        get|g)     do_op full "$peer" LOCAL_SELF ;;
        putinc|pi) do_op inc  LOCAL_SELF "$peer" ;;
        getinc|gi) do_op inc  "$peer" LOCAL_SELF ;;
      esac ;;

    transfer|trf)
      (( ${#POSARGS[@]} == 2 )) || die "Usage: xfsnap transfer SRC DST"
      do_op full "${POSARGS[0]}" "${POSARGS[1]}" ;;
    transferinc|trfi)
      (( ${#POSARGS[@]} == 2 )) || die "Usage: xfsnap transferinc SRC DST"
      do_op inc "${POSARGS[0]}" "${POSARGS[1]}" ;;

    clean|cl)      do_clean ;;
    check|doctor)  do_check "${POSARGS[0]:-}" ;;
    upgrade|up)    do_upgrade ;;
    *)             die "Unknown subcommand: $cmd (try 'xfsnap help')" ;;
  esac
}

main "$@"
